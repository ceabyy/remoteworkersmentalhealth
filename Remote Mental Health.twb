                <zone fixed-size='83' h='10618' id='15' name='Burnout Score vs. Hours Worked/wk' pane-specification-id='4' param='[federated.14fqtqb0t0xbcc14yfkgo0z6qybt].[none:Work_Mode:nk]' type-v2='color' w='15345' x='40612' y='933'>
                  <zone-style>
                    <format attr='border-color' value='#d4a6c8' />
                    <format attr='border-style' value='solid' />
                    <format attr='border-width' value='3' />
                    <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='5' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#fbf7fb' />
                  </zone-style>
                </zone>
                <zone fixed-size='221' forceUpdate='true' h='26721' id='19' type-v2='text' w='15345' x='40612' y='19485'>
                  <formatted-text>
                    <run fontcolor='#b07aa1'>Based off of the trend lines, it can be seen that </run>
                    <run bold='true' fontcolor='#b07aa1'>remote workers are less likely to burn out over longer working hours</run>
                    <run fontcolor='#b07aa1'>. The opposite effect is seen for Onsite Workers.</run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#b07aa1'>However, </run>
                    <run bold='true' fontcolor='#b07aa1'>hybrid workers tend to have a lower average burnout score</run>
                    <run fontcolor='#b07aa1'> past a normal number (40) of hours worked.</run>
                    <run>Æ&#10;&#10;&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='77014' id='32' is-fixed='true' name='Feature Importances for Burnout ' w='43428' x='55957' y='22053'>
                  <layout-cache cell-count-w='5' minheight='296' non-cell-size-w='63' type-h='scalable' type-w='cell' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='10' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#fbf7fb' />
                  </zone-style>
                </zone>
                <zone fixed-size='280' h='42824' id='22' is-fixed='true' name='Regions &amp; Work Life Balance' w='40037' x='615' y='56243'>
                  <layout-cache cell-count-w='7' minheight='152' non-cell-size-w='52' type-h='scalable' type-w='cell' />
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <_.fcp.DashboardRoundedCorners.true...format attr='corner-radius' value='10' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                    <format attr='background-color' value='#f3ebf3' />
                  </zone-style>
                </zone>
                <zone forceUpdate='true' h='24737' id='27' type-v2='text' w='15305' x='40652' y='69661'>
                  <formatted-text>
                    <run bold='true' fontcolor='#b07aa1'>Use the toggles above to toggle the work setup type (i.e. Remote, Hybrid, Onsite). </run>
                    <run>Æ&#10;&#10;</run>
                    <run fontcolor='#b07aa1'>Remote has the highest average work life balance rating out of all the setups (indiscriminate of the region), with a significant difference, demonstrating that </run>
                    <run bold='true' fontcolor='#b07aa1'>remote work arrangements provide better work life balance opportunities for employees.</run>
                    <run>Æ&#10;</run>
                  </formatted-text>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
                <zone h='13418' id='24' name='Regions &amp; Work Life Balance' synchronized='1' type-v2='currpage' w='15305' x='40652' y='56243'>
                  <zone-style>
                    <format attr='border-color' value='#000000' />
                    <format attr='border-style' value='none' />
                    <format attr='border-width' value='0' />
                    <format attr='margin' value='4' />
                    <format attr='padding' value='0' />
                  </zone-style>
                </zone>
              </zone>
              <zone-style>
                <format attr='border-color' value='#000000' />
